# Copier ce fichier en `terraform.tfvars` puis remplir.
# ⚠️ terraform.tfvars est dans .gitignore (il contient ton ID d'abonnement).

# ID de l'abonnement Azure : az account show --query id -o tsv
subscription_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# Ton IP publique en /32 (autorise SSH depuis ton poste) : curl ifconfig.me
my_public_ip = "203.0.113.5/32"

# Optionnels (valeurs par défaut sinon) :
# location            = "westeurope"
# vm_size             = "Standard_B2s"
# ssh_public_key_path = "~/.ssh/id_ed25519.pub"
