# Copier ce fichier en .env puis adapter les valeurs.
# ⚠️ .env NE DOIT JAMAIS être commité (il est dans .gitignore).
# En production, ces valeurs proviennent de GitHub Secrets, pas d'un fichier versionné.

# Mot de passe de la base PostgreSQL (local docker compose)
POSTGRES_PASSWORD=change_me_strong

# URL complète de la base (optionnel en local : reconstruite par docker-compose)
# DATABASE_URL=postgresql+psycopg://ticket:change_me_strong@postgres:5432/ticketing
